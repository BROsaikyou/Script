local function IsAlive(char)
    if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end
local function GetTargetsInRange(range)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
    local myPos = char.HumanoidRootPart.Position
    local targets = {}
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if enemiesFolder then
        for _, enemy in ipairs(enemiesFolder:GetChildren()) do
            local hrp = enemy:FindFirstChild("HumanoidRootPart")
            if hrp and IsAlive(enemy) and (hrp.Position - myPos).Magnitude <= range then
                table.insert(targets, enemy)
            end
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and IsAlive(player.Character) and (hrp.Position - myPos).Magnitude <= range then
                table.insert(targets, player.Character)
            end
        end
    end
    return targets
end
local function ExecuteAttack()
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local range = _G.AttackRange
    if char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart:FindFirstChild("Buddha") then
        range = 50000
    end
    local targets = GetTargetsInRange(range)
    if #targets == 0 then return end
    if tool:FindFirstChild("LeftClickRemote") then
        for i, target in ipairs(targets) do
            local targetHrp = target:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                local direction = (targetHrp.Position - char:GetPivot().Position).Unit
                tool.LeftClickRemote:FireServer(direction, i)
            end
        end
    else
        local hitList = {}
        local lastHitPart = nil
        for _, target in ipairs(targets) do
            if not target:GetAttribute("IsBoat") then
                local head = target:FindFirstChild("Head")
                if head then
                    table.insert(hitList, {target, head})
                    lastHitPart = head
                end
            end
        end
        if lastHitPart then
            local netFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
            local registerAttack = netFolder:WaitForChild("RE/RegisterAttack")
            local registerHit = netFolder:WaitForChild("RE/RegisterHit")
            pcall(function()
                registerAttack:FireServer(0.4)
                registerHit:FireServer(lastHitPart, hitList)
            end)
        end
    end
end
task.spawn(function()
    while true do
        if _G.FastAttackEnabled then
            pcall(ExecuteAttack)
        end
        task.wait(0.1)
    end
end)
